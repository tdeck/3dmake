[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
tweaker3 = {git = "https://github.com/ChristophSchranz/Tweaker-3.git", ref="v3.9.1"}
numpy-stl = "*"
requests = "*"
platformdirs = "*"
mslex = {version = "*", markers = "sys_platform == 'win32'"}
prompt_toolkit = "*"
prompt-toolkit = "*"
vtkplotlib = "*"
pillow = "*"
google-genai = "*"
openai = "*"
vtk = "*"
paho-mqtt = "*"
packaging = "*"

[dev-packages]
pyinstaller = "*"
pytest = "*"
pexpect = '*'
# These are transitive dependencies only used on Windows; we lock them here to avoid churn in Pipfile
pywin32-ctypes = {version = "*", markers = "sys_platform == 'win32'"}
pefile = {version = "*", markers = "sys_platform == 'win32'"}
colorama = {version = "*", markers = "sys_platform == 'win32'"}

[requires]
python_version = "3.13"
